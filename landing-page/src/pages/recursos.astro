---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import FeatureHighlight from '@sections/marketing/FeatureHighlight.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';
/**
 * Lumos - Landing Page Configuration
 * Substituindo funcionalidades de infraestrutura por funcionalidades de Gestão de Iluminação Pública.
 */

const highlightedFeatures = [
  {
    title: 'Mapa Operacional em Tempo Real',
    description:
      'Visualize tudo o que está acontecendo no campo em um único mapa inteligente. Acompanhe execuções em andamento e finalizadas com precisão geográfica, incluindo instalações e manutenções, com acesso imediato a fotos, etiquetas e dados de cada ponto.',
    image: '/images/map-executions.png',
    badge: 'Operacional',
    highlights: [
      'Visualização em tempo real das execuções no mapa',
      'Pontos georreferenciados com alta precisão',
      'Identificação por número de etiqueta de cada ativo',
      'Acesso a fotos e detalhes diretamente no mapa',
      'Monitoramento de instalações e manutenções em andamento e concluídas',
    ],
    // cta: { label: 'Explorar mapa', href: '/solucoes/mapa' },
  },
  {
    title: 'Vínculo Contratual Inteligente',
    description:
      'Mesmo quando a execução em campo acontece sem Ordem de Serviço, seu faturamento continua seguro. O sistema permite vincular posteriormente os serviços e materiais executados aos itens contratuais, garantindo rastreabilidade, conformidade e precisão na medição.',
    icon: 'lucide:link-2',
    badge: 'Financeiro',
    highlights: [
      'Execução em campo sem O.S., sem perder controle contratual',
      'Vinculação posterior de materiais e serviços ao contrato',
      'Rastreabilidade completa entre execução e faturamento',
      'Redução de glosas com validação baseada em contrato',
      'Cálculo automático dos valores conforme itens contratuais',
    ],
    // cta: { label: 'Entenda o faturamento', href: '/solucoes/contratos' },
  },
  {
    title: 'Relatórios de Execução e Faturamento',
    description:
      'Transforme as execuções de campo em relatórios completos e prontos para faturamento e prestação de contas. Tenha controle total das atividades realizadas, com dados organizados para auditorias, medições contratuais e transparência junto às prefeituras.',
    image: '/images/installation-report.jpeg',
    badge: 'Gestão & Financeiro',
    highlights: [
      'Relatórios detalhados de instalações e manutenções',
      'Base confiável para faturamento e medições',
      'Prestação de contas clara para prefeituras',
      'Histórico completo e auditável das execuções',
      'Padronização e organização das informações operacionais',
    ],
    // cta: { label: 'Ver relatórios', href: '/solucoes/relatorios' },
  },
  {
    title: 'Relatórios com Assinatura do Fiscal em Campo',
    description:
      'Inclua nos relatórios a assinatura do responsável da prefeitura coletada diretamente em campo. Cada execução passa a contar com validação formal no próprio documento, fortalecendo a comprovação dos serviços realizados e reduzindo riscos de questionamentos em medições e auditorias.',
    image: '/images/installation-report-sign-section.jpeg',
    badge: 'Relatórios & Validação',
    highlights: [
      'Assinatura do fiscal incorporada automaticamente ao relatório',
      'Validação formal das execuções no próprio documento',
      'Mais segurança nas medições e no faturamento',
      'Redução de glosas e questionamentos',
      'Registro integrado com data, hora e evidências da execução',
    ],
    // cta: { label: 'Ver exemplo de relatório', href: '/solucoes/relatorios' },
  },
  {
    title: 'Assinatura em Campo com Validação do Responsável',
    description:
      'Garanta a validação imediata das execuções diretamente em campo com assinatura do responsável da prefeitura. Elimine retrabalho, reduza questionamentos e fortaleça a segurança jurídica das medições com registros vinculados à execução, data, localização e evidências.',
    image: '/images/marketing-app-sign.png',
    badge: 'Controle & Auditoria',
    highlights: [
      'Assinatura digital do fiscal diretamente no local da execução',
      'Validação instantânea das atividades realizadas',
      'Redução de glosas e questionamentos em medições',
      'Registro com data, hora e geolocalização vinculados',
      'Mais segurança jurídica para faturamento e prestação de contas',
    ],
    cta: { label: 'Ver como funciona', href: '/assinatura-em-campo-iluminacao-publica' },
  },
  {
    title: 'Gestão de Estoque Inteligente',
    description:
      'Controle total dos seus materiais com agilidade e precisão. Gerencie entradas, saídas e movimentações com leitura de código de barras, mantenha seu catálogo organizado e tenha rastreabilidade completa para evitar perdas e garantir eficiência operacional.',
    image: '/images/features/inventory.webp',
    badge: 'Estoque',
    highlights: [
      'Cadastro e movimentação via leitura de código de barras',
      'Entrada de materiais integrada com notas fiscais',
      'Impressão de etiquetas para identificação e rastreio',
      'Relatórios completos de estoque em tempo real',
      'Catálogo organizado e de fácil consulta',
      'Rastreabilidade de materiais do recebimento até a aplicação',
    ],
    // cta: { label: 'Gerenciar estoque', href: '/solucoes/estoque' },
  },
  {
    title: 'Dashboard de Indicadores (KPIs)',
    description:
      'Tenha uma visão clara da produtividade e da saúde dos seus contratos em tempo real. Acompanhe o desempenho por equipe ou colaborador, monitore saldos contratuais e tome decisões rápidas com base em dados confiáveis.',
    icon: 'lucide:bar-chart-3',
    badge: 'Estratégico',
    highlights: [
      'Produtividade detalhada por equipe e por colaborador',
      'Acompanhamento de metas operacionais em tempo real',
      'Visão de saldo e consumo por contrato',
      'Identificação rápida de gargalos e baixa performance',
      'Indicadores atualizados automaticamente com base nas execuções',
    ],
    // cta: { label: 'Explorar dashboards', href: '/funcionalidades/dashboards' },
  },
];

const bentoFeatures = [
  {
    title: 'Execuções sem Ordem de Serviço',
    description:
      'Receba notificações e Identifique rapidamente instalações que ainda não foram vinculadas ao contrato para não perder prazos de cobrança.',
    icon: 'lucide:alert-circle',
    size: 'large' as const,
    accent: 'primary' as const,
    // href: '/funcionalidades/validacao',
  },
  {
    title: 'Logs de Operação',
    description: 'Rastro completo de quem executou, quem validou e quando o item foi faturado.',
    icon: 'lucide:clipboard-list',
    accent: 'blue' as const,
  },
  {
    title: 'Segurança de Dados',
    description: 'Gestão segura de inventários e dados sensíveis de contratos municipais.',
    icon: 'lucide:shield-check',
    accent: 'green' as const,
  },
  {
    title: 'Equipes de Campo',
    description:
      'Gestão de usuários com permissões específicas para eletricistas, fiscais e administradores.',
    icon: 'lucide:users',
    size: 'medium' as const,
    accent: 'purple' as const,
    // href: '/solucoes/equipes',
  },
];

const featureCategories = [
  {
    title: 'Operação',
    subtitle: 'Eficiência operacional total',
    items: [
      {
        icon: 'lucide:zap',
        title: 'Execução Rápida',
        description:
          'Fluxo de trabalho otimizado para que a equipe gaste menos tempo com burocracia e mais tempo batendo metas de produção.',
      },
      {
        icon: 'lucide:map-pin',
        title: 'Georreferenciamento',
        description:
          'Todos os pontos de iluminação mapeados. Saiba exatamente onde cada equipe está e onde o serviço foi realizado.',
      },
      {
        icon: 'lucide:camera',
        title: 'Evidências Fotográficas',
        description:
          'Obrigatório para validação: fotos de antes e depois com marca d’água de data e hora automáticas.',
      },
      {
        icon: 'lucide:package',
        title: 'Controle de Materiais',
        description:
          'Baixa automática de estoque de lâmpadas, reatores e luminárias LED conforme a execução das ordens de serviço.',
      },
    ],
  },
  {
    title: 'Contratos e Compliance',
    subtitle: 'Gestão rigorosa para evitar perdas financeiras',
    items: [
      {
        icon: 'lucide:file-signature',
        title: 'Itens Contratuais',
        description:
          'Cadastre tabelas de preços e itens (ex: Instalação de Braço 2m) para vínculo direto com a produção.',
      },
      {
        icon: 'lucide:check-square',
        title: 'Validação de Execuções',
        description:
          'Fluxo de vínculo contratual: o operador víncula e revisa os materiais executados em campo com itens reais do contrato.',
      },
      {
        icon: 'lucide:history',
        title: 'Auditabilidade',
        description:
          'Histórico imutável de todas as alterações em medições, garantindo total transparência.',
      },
      {
        icon: 'lucide:file-spreadsheet',
        title: 'Exportação Direta',
        description:
          'Gere relatórios de execuções prontos para o protocolo na prefeitura com um clique.',
      },
    ],
  },
];
---

<MarketingLayout
  title={`Funcionalidades - Lumos`}
  description="Descubra como o Lumos transforma a gestão de iluminação pública com foco em execução, vínculo contratual e eficiência operacional."
>
  <PageHeader
    title="O único sistema que conecta execução em campo diretamente ao seu contrato."
    subtitle="Pare de perder dinheiro com glosas e falta de controle. O Lumos automatiza a gestão de campo, garante rastreabilidade completa e transforma sua execução em faturamento seguro."
  />

  <FeatureHighlight
    title="Funcionalidades em Detalhe"
    subtitle="Mergulhe nas capacidades que tornam o Lumos a plataforma líder em gestão operacional de ativos."
    features={highlightedFeatures}
    background="muted"
  />

  {
    featureCategories.map((category, index) => (
      <ValuesSection
        title={category.title}
        subtitle={category.subtitle}
        items={category.items}
        variant="with-icon"
        columns={2}
        background={index % 2 === 0 ? 'muted' : 'default'}
      />
    ))
  }

  <BentoGrid
    title="E muito mais"
    subtitle="Descubra as ferramentas que tornam o fluxo de trabalho da sua equipe impecável."
    items={bentoFeatures}
    background="muted"
  />

  <CTA
    title="Pronto para iluminar sua gestão?"
    description="Comece a otimizar suas medições e o controle de campo com o Lumos hoje mesmo."
    action={{ label: 'Solicitar Demonstração', href: '/demonstracao' }}
    background="muted"
  />
</MarketingLayout>