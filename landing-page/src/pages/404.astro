---
import ErrorLayout from '@/layouts/ErrorLayout.astro';
import ErrorPage from '@components/error/ErrorPage.astro';
---

<ErrorLayout title="Página Não Encontrada" description="A página que você está procurando não existe.">
  <ErrorPage
    code={404}
    title="Página Não Encontrada"
    message="Desculpe, não conseguimos encontrar a página que você está procurando. Ela pode ter sido movida, excluída ou nunca ter existido."
  />
</ErrorLayout>
