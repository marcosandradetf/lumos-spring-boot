---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import DemoRequestForm from '@forms/DemoRequestForm.astro';
import { Icon } from 'astro-icon/components';

const gainHighlights = [
  {
    icon: 'lucide:boxes',
    title: 'Gerenciamento de estoque em tempo real',
    description:
      'Movimentação rastreada por equipe, veículo e almoxarifado sem planilhas paralelas.',
  },
  {
    icon: 'lucide:map',
    title: 'Mapa Operacional em Tempo Real',
    description: 'Visualize tudo o que está acontecendo no campo em um único mapa inteligente.',
  },
  {
    icon: 'lucide:file-text',
    title: 'Relatórios de Execução e Faturamento',
    description:
      'Transforme as execuções de campo em relatórios completos e prontos para faturamento e prestação de contas.',
  },
  {
    icon: 'lucide:navigation',
    title: 'Modo Ronda de Operação',
    description:
      'Percorra a cidade identificando pontos de iluminação pública que precisam de manutenção.',
  },
];

const assurances = [
  {
    icon: 'lucide:credit-card',
    text: 'Sem cartão',
  },
  {
    icon: 'lucide:calendar-clock',
    text: '14 dias',
  },
  {
    icon: 'lucide:shield-check',
    text: 'Acesso seguro',
  },
];

const faqs = [
  {
    question: 'Em quanto tempo consigo começar?',
    answer:
      'O cadastro leva poucos minutos e o primeiro acesso já te direciona para validar os recursos principais.',
  },
  {
    question: 'Precisa cartão ou compromisso de contratação?',
    answer: 'Não. O teste é gratuito, sem cartão e sem obrigação de continuidade.',
  },
  {
    question: 'O suporte ajuda durante o teste?',
    answer:
      'Sim. Nosso time apoia o seu primeiro acesso para você tirar resultado rápido da avaliação.',
  },
];
---

<MarketingLayout
  title="Teste Grátis"
  description="Comece seu teste grátis no Lumos e veja como conectar execução em campo ao contrato."
>
  <section class="bg-[var(--color-background)] py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-8 lg:gap-14 items-start">
        <div class="lg:sticky lg:top-8">
          <span
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold bg-[var(--color-primary)]/10 text-[var(--color-primary)] mb-5"
          >
            <Icon name="lucide:sparkles" class="w-3.5 h-3.5" />
            Primeiro acesso Lumos IP
          </span>

          <h1
            class="text-3xl sm:text-5xl font-bold text-[var(--color-text)] tracking-tight leading-[1.08]"
          >
            Modernize sua operação
          </h1>

          <p class="text-base sm:text-lg text-[var(--color-text-muted)] mt-5 leading-relaxed">
            Processo rápido, sem compromisso e com foco no que realmente importa: produtividade de
            campo, controle contratual e visibilidade de ponta a ponta.
          </p>

          <div class="mt-7 space-y-3">
            {
              gainHighlights.map((item) => (
                <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]/70 px-4 py-4 transition-all hover:border-[var(--color-primary)]/40 hover:shadow-md">
                  <div class="flex items-start gap-3">
                    <span class="mt-0.5 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
                      <Icon name={item.icon} class="h-4.5 w-4.5" />
                    </span>
                    <div>
                      <p class="text-sm font-semibold text-[var(--color-text)]">{item.title}</p>
                      <p class="mt-1 text-sm leading-relaxed text-[var(--color-text-muted)]">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          <div class="mt-6 grid grid-cols-3 gap-2 sm:gap-3">
            {
              assurances.map((item) => (
                <div class="min-h-20 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-4 text-center">
                  <Icon name={item.icon} class="mx-auto mb-2 h-5 w-5 text-[var(--color-primary)]" />
                  <span class="text-xs font-semibold text-[var(--color-text)]">{item.text}</span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="space-y-5">
          <div
            class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-5 sm:p-7 shadow-xl relative overflow-hidden"
          >
            <div
              class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-[var(--color-primary)] to-transparent opacity-50"
            >
            </div>

            <div class="mb-8 text-center lg:text-left">
              <div
                class="mx-auto lg:mx-0 mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--color-primary)] text-white"
              >
                <Icon name="lucide:play" class="h-5 w-5" />
              </div>
              <h2 class="text-xl sm:text-2xl font-bold text-[var(--color-text)]">
                Inicie seu primeiro acesso
              </h2>
              <p class="text-sm text-[var(--color-text-muted)] mt-1">
                Fluxo rápido, guiado e sem compromisso para você validar o Lumos com segurança.
              </p>
            </div>

            <DemoRequestForm
              action="https://api.lumosip.com.br/spring/public/free-test"
              variant="free-test"
              formName="free-test"
              planName="Profissional"
              submitLabel="Criar conta e iniciar teste"
            />

            <div
              class="mt-5 flex items-start gap-2 rounded-xl bg-[var(--color-background)] px-4 py-3 text-xs text-[var(--color-text-muted)]"
            >
              <Icon name="lucide:shield-check" class="mt-0.5 h-4 w-4 shrink-0 text-green-500" />
              <span>
                Seus dados são usados apenas para preparar seu ambiente de teste e apoiar seus
                primeiros passos no Lumos.
              </span>
            </div>
          </div>

          <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 sm:p-7">
            <div class="flex items-start gap-3">
              <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[var(--color-primary)]/12 text-[var(--color-primary)]">
                <Icon name="lucide:shield-check" class="h-4.5 w-4.5" />
              </span>
              <div>
                <h2 class="text-lg sm:text-xl font-bold text-[var(--color-text)]">
                  Começo simples e assistido
                </h2>
                <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
                  Após criar sua conta, o sistema inicia um onboarding automático para guiar os
                  primeiros passos com clareza e segurança.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FAQ Section */}
  <section class="py-12 sm:py-14 border-t border-[var(--color-border)] bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-primary)]">
          Confiança para decidir
        </p>
        <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text)] tracking-tight">
          Dúvidas frequentes sobre o teste grátis
        </h2>
      </div>

      <div
        class="divide-y divide-[var(--color-border)] rounded-2xl border border-[var(--color-border)] bg-[var(--color-background)]"
      >
        {
          faqs.map((faq) => (
            <div class="p-5 sm:p-6">
              <h3 class="font-bold text-[var(--color-text)]">{faq.question}</h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed font-medium">
                {faq.answer}
              </p>
            </div>
          ))
        }
      </div>

      <div
        class="mt-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-background)] p-5 sm:p-6"
      >
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-primary)]">
          Depoimentos
        </p>

        <div>
          <p class="mt-2 text-sm sm:text-base leading-relaxed text-[var(--color-text)]">
            "O maior ganho foi eliminar as planilhas de campo. No primeiro acesso, já conseguimos
            espelhar nossa rotina de almoxarifado e veículos para dentro do Lumos, conectando a
            execução ao contrato de forma automática."
          </p>
          <p class="mt-3 text-xs font-semibold text-[var(--color-text-muted)]">
            Eng. de Operações • Setor de Iluminação Pública
          </p>
        </div>
        <br>
        <div>
          <p class="mt-2 text-sm sm:text-base leading-relaxed text-[var(--color-text)]">
            "Precisávamos de agilidade na prestação de contas. Com o Lumos, a ronda identifica o ponto e o relatório de faturamento já sai pronto. A visibilidade do que é executado em tempo real mudou nossa produtividade."
          </p>
          <p class="mt-3 text-xs font-semibold text-[var(--color-text-muted)]">
            Gestor de Contratos • Consórcio de IP
          </p>
        </div>


      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  :global(#demo-request-form input),
  :global(#demo-request-form select) {
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  :global(#demo-request-form input:hover),
  :global(#demo-request-form select:hover) {
    border-color: color-mix(in oklab, var(--color-primary) 42%, var(--color-border));
  }

  :global(#demo-request-form input:focus),
  :global(#demo-request-form select:focus) {
    border-color: color-mix(in oklab, var(--color-primary) 65%, white);
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--color-primary) 20%, transparent),
      0 8px 24px -14px color-mix(in oklab, var(--color-primary) 50%, transparent);
  }
</style>
