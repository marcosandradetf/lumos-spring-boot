---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import FeatureHighlight from '@sections/marketing/FeatureHighlight.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';
/**
 * Lumos - Landing Page Configuration
 * Substituindo funcionalidades de infraestrutura por funcionalidades de Gestão de Iluminação Pública.
 */

const highlightedFeatures = [
  {
    title: 'Gestão de Execuções em Tempo Real',
    description:
      'Acompanhe cada instalação ou manutenção assim que ela é finalizada no campo. Elimine o papelório e tenha uma visão clara da produção diária da sua equipe com fotos e geolocalização.',
    image: '/images/features/field-operation.webp',
    badge: 'Operacional',
    highlights: [
      'Sincronização instantânea com a equipe de campo',
      'Registro fotográfico e coordenadas GPS por ponto',
      'Status de execução atualizado em tempo real',
      'Histórico completo de intervenções por poste',
    ],
    // cta: { label: 'Ver gestão de campo', href: '/solucoes/campo' },
  },
  {
    title: 'Vínculo Contratual Inteligente',
    description:
      'O maior gargalo da iluminação pública resolvido. Vincule execuções prontas aos itens do contrato automaticamente para gerar medições precisas e acelerar o faturamento.',
    icon: 'lucide:link-2',
    badge: 'Financeiro',
    highlights: [
      'Associação direta com itens da planilha orçamentária',
      'Validação de conformidade antes do fechamento',
      'Redução drástica de glosas em medições',
      'Cálculo automático de valores contratuais',
    ],
    // cta: { label: 'Entenda o faturamento', href: '/solucoes/contratos' },
  },
  {
    title: 'Dashboard de Indicadores (KPIs)',
    description:
      'Tome decisões baseadas em dados. Visualize o desempenho da sua PPP ou contrato de manutenção através de painéis intuitivos que mostram desde o tempo médio de reparo até a economia de energia.',
    icon: 'lucide:bar-chart-3',
    badge: 'Estratégico',
    highlights: [
      'Relatórios automáticos para prefeituras e consórcios',
      'Acompanhamento de metas contratuais (SLAs)',
      'Mapa de calor de falhas e manutenções',
      'Exportação de dados para auditorias',
    ],
    // cta: { label: 'Explorar dashboards', href: '/funcionalidades/dashboards' },
  },
];

const bentoFeatures = [
  {
    title: 'Pendente de Vínculo',
    description:
      'Receba notificações e Identifique rapidamente instalações que ainda não foram vinculadas ao contrato para não perder prazos de cobrança.',
    icon: 'lucide:alert-circle',
    size: 'large' as const,
    accent: 'primary' as const,
    // href: '/funcionalidades/validacao',
  },
  {
    title: 'Logs de Operação',
    description: 'Rastro completo de quem executou, quem validou e quando o item foi faturado.',
    icon: 'lucide:clipboard-list',
    accent: 'blue' as const,
  },
  {
    title: 'Segurança de Dados',
    description: 'Gestão segura de inventários e dados sensíveis de contratos municipais.',
    icon: 'lucide:shield-check',
    accent: 'green' as const,
  },
  {
    title: 'Equipes de Campo',
    description:
      'Gestão de usuários com permissões específicas para eletricistas, fiscais e administradores.',
    icon: 'lucide:users',
    size: 'medium' as const,
    accent: 'purple' as const,
    // href: '/solucoes/equipes',
  },
];

const featureCategories = [
  {
    title: 'Operação',
    subtitle: 'Eficiência operacional total',
    items: [
      {
        icon: 'lucide:zap',
        title: 'Execução Rápida',
        description:
          'Fluxo de trabalho otimizado para que a equipe gaste menos tempo com burocracia e mais tempo batendo metas de produção.',
      },
      {
        icon: 'lucide:map-pin',
        title: 'Georreferenciamento',
        description:
          'Todos os pontos de iluminação mapeados. Saiba exatamente onde cada equipe está e onde o serviço foi realizado.',
      },
      {
        icon: 'lucide:camera',
        title: 'Evidências Fotográficas',
        description:
          'Obrigatório para validação: fotos de antes e depois com marca d’água de data e hora automáticas.',
      },
      {
        icon: 'lucide:package',
        title: 'Controle de Materiais',
        description:
          'Baixa automática de estoque de lâmpadas, reatores e luminárias LED conforme a execução das ordens de serviço.',
      },
    ],
  },
  {
    title: 'Contratos e Compliance',
    subtitle: 'Gestão rigorosa para evitar perdas financeiras',
    items: [
      {
        icon: 'lucide:file-signature',
        title: 'Itens Contratuais',
        description:
          'Cadastre tabelas de preços e itens (ex: Instalação de Braço 2m) para vínculo direto com a produção.',
      },
      {
        icon: 'lucide:check-square',
        title: 'Validação de Execuções',
        description:
          'Fluxo de vínculo contratual: o operador víncula e revisa os materiais executados em campo com itens reais do contrato.',
      },
      {
        icon: 'lucide:history',
        title: 'Auditabilidade',
        description:
          'Histórico imutável de todas as alterações em medições, garantindo total transparência.',
      },
      {
        icon: 'lucide:file-spreadsheet',
        title: 'Exportação Direta',
        description:
          'Gere relatórios de execuções prontos para o protocolo na prefeitura com um clique.',
      },
    ],
  },
];
---

<MarketingLayout
  title={`Funcionalidades - Lumos`}
  description="Descubra como o Lumos transforma a gestão de iluminação pública com foco em execução, vínculo contratual e eficiência operacional."
>
  <PageHeader
    title="Sua operação de iluminação pública, do campo ao faturamento, sem gargalos."
    subtitle="O Lumos automatiza o vínculo contratual e a gestão de campo para que empresas e consórcios de IP foquem no que importa: resultados."
  />

  <FeatureHighlight
    title="Funcionalidades em Detalhe"
    subtitle="Mergulhe nas capacidades que tornam o Lumos a plataforma líder em gestão operacional de ativos."
    features={highlightedFeatures}
    background="muted"
  />

  {
    featureCategories.map((category, index) => (
      <ValuesSection
        title={category.title}
        subtitle={category.subtitle}
        items={category.items}
        variant="with-icon"
        columns={2}
        background={index % 2 === 0 ? 'muted' : 'default'}
      />
    ))
  }

  <BentoGrid
    title="E muito mais"
    subtitle="Descubra as ferramentas que tornam o fluxo de trabalho da sua equipe impecável."
    items={bentoFeatures}
    background="muted"
  />

  <CTA
    title="Pronto para iluminar sua gestão?"
    description="Comece a otimizar suas medições e o controle de campo com o Lumos hoje mesmo."
    action={{ label: 'Solicitar Demo', href: '/contact' }}
    background="muted"
  />
</MarketingLayout>