---
/**
 * Lumos - Centro de Conhecimento
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

type DocsEntry = CollectionEntry<'docs'>;

const allDocs = await getCollection('docs', ({ data }: { data: DocsEntry['data'] }) => !data.draft);

interface DocItem {
  title: string;
  description: string;
  slug: string;
  order: number;
}

interface DocsSection {
  section: string;
  items: DocItem[];
}

const sectionMap = new Map<string, DocItem[]>();

for (const doc of allDocs) {
  const sectionName = doc.data.section;
  if (!sectionMap.has(sectionName)) {
    sectionMap.set(sectionName, []);
  }
  sectionMap.get(sectionName)!.push({
    title: doc.data.title,
    description: doc.data.description,
    slug: doc.id,
    order: doc.data.order,
  });
}

const docsSections: DocsSection[] = [];
for (const [sectionName, items] of sectionMap) {
  items.sort((a, b) => a.order - b.order);
  docsSections.push({ section: sectionName, items });
}

docsSections.sort((a, b) => {
  const aMinOrder = Math.min(...a.items.map((i) => i.order));
  const bMinOrder = Math.min(...b.items.map((i) => i.order));
  return aMinOrder - bMinOrder;
});

const firstDoc = allDocs.sort((a: DocsEntry, b: DocsEntry) => a.data.order - b.data.order)[0];

const sectionIcons: Record<string, string> = {
  Introdução: 'lucide:info',
  'Gestão de Acesso': 'lucide:shield-check',
  Estoque: 'lucide:package',
  Contratos: 'lucide:file-signature',
  Operacional: 'lucide:hard-hat',
  Relatórios: 'lucide:bar-chart-3',
  FAQ: 'lucide:help-circle',
};

function getSectionIcon(section: string): string {
  return sectionIcons[section] || 'lucide:file-text';
}
---

<MarketingLayout
  title={`Centro de Conhecimento`}
  description="Domine a gestão de iluminação pública. Guias técnicos e operacionais para equipes e gestores."
>
  <section class="py-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-text">Centro de Conhecimento</h1>
      <p class="mt-6 text-lg text-text-muted max-w-2xl mx-auto">
        Da configuração de contratos à liquidação financeira de campo. Tudo o que você precisa para
        dominar a operação do Lumos.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        {
          firstDoc && (
            <a
              href={`/como-usar/${firstDoc.id}`}
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md bg-primary text-white font-medium hover:bg-primary-dark transition-all"
            >
              <Icon name="lucide:rocket" class="w-5 h-5" />
              Começar o Treinamento
            </a>
          )
        }
        <a
          href="#sections"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md border border-border bg-background text-text font-medium hover:bg-surface transition-all"
        >
          <Icon name="lucide:list" class="w-5 h-5" />
          Navegar por Módulos
        </a>
      </div>
    </div>
  </section>

  <section class="py-12 border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a
          href="/como-usar/02-access-management/01-profiles"
          class="flex items-center gap-3 p-4 rounded-lg bg-surface hover:bg-surface/80 transition-all group"
        >
          <div
            class="p-2 rounded-md bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors"
          >
            <Icon name="lucide:users" class="w-5 h-5" />
          </div>
          <span class="font-medium text-text">Usuários</span>
        </a>
        <a
          href="/como-usar/01-introduction/03-mobile-app-getting-started"
          class="flex items-center gap-3 p-4 rounded-lg bg-surface hover:bg-surface/80 transition-all group"
        >
          <div
            class="p-2 rounded-md bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors"
          >
            <Icon name="lucide:package" class="w-5 h-5" />
          </div>
          <span class="font-medium text-text">App Mobile</span>
        </a>
        <a
          href="/como-usar/01-introduction/02-first-access"
          class="flex items-center gap-3 p-4 rounded-lg bg-surface hover:bg-surface/80 transition-all group"
        >
          <div
            class="p-2 rounded-md bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors"
          >
            <Icon name="lucide:file-text" class="w-5 h-5" />
          </div>
          <span class="font-medium text-text">Primeiro Acesso</span>
        </a>
        <a
          href="/como-usar/01-introduction/01-general-vision"
          class="flex items-center gap-3 p-4 rounded-lg bg-surface hover:bg-surface/80 transition-all group"
        >
          <div
            class="p-2 rounded-md bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors"
          >
            <Icon name="lucide:zap" class="w-5 h-5" />
          </div>
          <span class="font-medium text-text">Visão Geral</span>
        </a>
      </div>
    </div>
  </section>

  <section id="sections" class="py-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {
          docsSections.map((section) => (
            <div>
              <div class="flex items-center gap-3 mb-6">
                <div class="p-2 rounded-md bg-primary/10 text-primary">
                  <Icon name={getSectionIcon(section.section)} class="w-6 h-6" />
                </div>
                <h2 class="text-2xl font-bold text-text">{section.section}</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {section.items.map((doc) => (
                  <a
                    href={`/como-usar/${doc.slug}`}
                    class="block p-6 rounded-lg border border-border bg-background hover:border-primary hover:shadow-lg transition-all group"
                  >
                    <h3 class="font-semibold text-text group-hover:text-primary transition-colors text-lg">
                      {doc.title}
                    </h3>
                    <p class="mt-2 text-sm text-text-muted line-clamp-2">{doc.description}</p>
                    <div class="mt-4 flex items-center gap-1 text-sm text-primary font-bold">
                      Acessar manual
                      <Icon
                        name="lucide:arrow-right"
                        class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                      />
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-section bg-surface border-t border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-text">Dúvidas com a implantação?</h2>
      <p class="mt-4 text-text-muted max-w-xl mx-auto">
        Nosso corpo técnico está à disposição para auxiliar na configuração inicial do seu contrato
        e treinamento da equipe de campo.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contato"
          class="bg-primary text-white px-6 py-3 rounded-md font-medium hover:bg-primary-dark transition-all inline-flex items-center gap-2"
        >
          <Icon name="lucide:headphones" class="w-5 h-5" />
          Suporte Técnico
        </a>
        <a
          href="/faq"
          class="border border-border bg-background px-6 py-3 rounded-md font-medium hover:bg-surface transition-all inline-flex items-center gap-2"
        >
          <Icon name="lucide:help-circle" class="w-5 h-5" />
          Perguntas Frequentes
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
