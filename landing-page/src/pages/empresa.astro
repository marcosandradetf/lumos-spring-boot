---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import { siteConfig } from '@/config';
import CTA from '@sections/marketing/CTA.astro';

const values = [
  {
    title: 'Precisão Inegociável',
    description:
      'Acreditamos que na gestão pública não existe espaço para o "eu acho". Cada dado no Lumos é uma evidência técnica real.',
    icon: 'lucide:target',
  },
  {
    title: 'Foco na Ponta',
    description:
      'Nossa tecnologia nasce de quem entende o trecho. O sistema existe para servir à operação, e não o contrário.',
    icon: 'lucide:hard-hat',
  },
  {
    title: 'Integridade Contratual',
    description:
      'Construímos o Lumos para ser o escudo jurídico e financeiro de quem opera concessões de longo prazo.',
    icon: 'lucide:shield-check',
  },
];

const milestones = [
  {
    year: 'A Origem',
    title: 'O Caos do Papel',
    description:
      'O Lumos nasceu da observação direta do desperdício: equipes de campo perdidas em planilhas e medições sendo contestadas por falta de provas.',
  },
  {
    year: 'A Inovação',
    title: 'Inteligência de Vínculo',
    description:
      'Desenvolvemos o primeiro motor de associação direta entre execução de campo e itens contratuais, eliminando o atraso no faturamento.',
  },
  {
    year: 'Hoje',
    title: 'Padrão de Mercado',
    description:
      'Consolidado como a ferramenta de elite para quem busca governança absoluta em ativos de iluminação pública.',
  },
];
---

<MarketingLayout
  title={`Sobre o Lumos - Nossa História`}
  description="Conheça a origem do Lumos e como estamos redefinindo o padrão de gestão em iluminação pública no Brasil."
>
  <Hero
    title="Não é mais um software. É o novo padrão de operação."
    subtitle="O Lumos surgiu da necessidade de substituir o improviso pela engenharia de dados. Entendemos que iluminação pública é infraestrutura crítica e exige gestão de elite."
    background="default"
    primaryCTA={
      {
        label: 'Entre em contato',
        href: '/contato'
      }
    }
  />

  <section class="py-20 px-6 max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-bold mb-6 text-primary">A nossa tese</h2>
        <p class="text-lg text-muted-foreground mb-4">
          A maioria dos sistemas de gestão falha porque é desenhada por quem nunca pisou em um
          canteiro de obras. Eles focam no gráfico bonito, mas esquecem da dificuldade de um
          eletricista no topo de um poste.
        </p>
        <p class="text-lg text-muted-foreground">
          O <strong>Lumos</strong> foi forjado no mundo real. Nossa história é sobre dar voz aos dados de campo e
          segurança aos diretores que assinam as medições. Unimos o rigor do desenvolvimento de
          software com o pragmatismo da operação de rua.
        </p>
      </div>
      <div class="bg-muted rounded-2xl p-8 border border-border">
        <blockquote class="text-xl italic font-medium">
          "No Lumos, não gerenciamos apenas LEDs. Gerenciamos a confiança entre o poder público,
          a concessionária e o cidadão."
        </blockquote>
      </div>
    </div>
  </section>

  <StatsSection
    stats={[
      { value: '100%', label: 'Foco em IP' },
      { value: 'Segurança', label: 'Jurídica' },
      { value: 'Agilidade', label: 'no Faturamento' },
    ]}
    background="muted"
  />

  <section class="py-20 px-6 bg-default">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-16">Nossos Pilares</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {
          values.map((value) => (
            <div class="p-8 rounded-xl border border-border bg-card hover:shadow-lg transition-shadow">
              <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-6 text-primary">
                <i data-lucide={value.icon} />
              </div>
              <h3 class="text-xl font-bold mb-3">{value.title}</h3>
              <p class="text-muted-foreground">{value.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-muted">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-16">Nossa Evolução</h2>
      <div class="space-y-12">
        {
          milestones.map((item) => (
            <div class="flex gap-8 items-start">
              <div class="text-2xl font-black text-primary/40 pt-1">{item.year}</div>
              <div>
                <h3 class="text-2xl font-bold mb-2">{item.title}</h3>
                <p class="text-lg text-muted-foreground">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA
    title="Faça parte da nova era da gestão pública."
    description="O Lumos é para quem não aceita menos que a excelência operacional. Vamos conversar sobre o futuro da sua concessão?"
    action={{ label: 'Falar conosco', href: '/contract' }}
    background="accent"
  />
</MarketingLayout>
