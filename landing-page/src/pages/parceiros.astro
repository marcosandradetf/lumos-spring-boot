---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import CaseStudyCard from '@sections/social-proof/CaseStudyCard.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import CTA from '@sections/marketing/CTA.astro';
import { siteConfig } from '@/config';

/**
 * Lumos - Customer Stories
 * Focado em provas sociais reais e métricas de impacto no setor de Iluminação Pública.
 */

const featuredCases = [
  {
    company: '', // Substitua pelo nome real do seu cliente
    logo: '',
    industry: '',
    quote:
      'O Lumos eliminou o atraso entre a execução no campo e o faturamento. O que levava semanas para ser validado agora é vinculado ao contrato em segundos, garantindo nosso fluxo de caixa.',
    author: 'Gabriela Oliveira',
    role: 'Analista de Qualidade e Planejamento',
    metrics: [
      { value: '100%', label: 'Itens Vinculados' },
      { value: '+10.000', label: 'Pontos finalizados' },
      { value: '40%', label: 'Mais Agilidade' },
      { value: '+500', label: 'Cidades atendidas' },
    ],
    // href: '#',
    featured: true,
  },
];

// Comentamos ou removemos o gridCases enquanto você escala
const gridCases = [];

const stats = [
  { value: '100%', label: 'Conformidade Contratual' },
  { value: '24/7', label: 'Monitoramento de Ativos' },
  { value: 'Redução', label: 'de Erros de Digitação' },
  { value: 'Agilidade', label: 'no Faturamento' },
];
---

<MarketingLayout
  title={`Casos de Sucesso - Lumos`}
  description="Veja como o Lumos ajuda empresas de iluminação pública a otimizarem seus processos e garantirem faturamento preciso."
>
  <PageHeader
    title="A diferença entre gerir iluminação e dominar um contrato de 20 anos."
    subtitle="O Lumos eleva o padrão da sua operação, transformando execuções complexas em ativos financeiros auditáveis e de liquidação imediata."
  />
  <StatsSection stats={stats} background="muted" />

  {featuredCases.length > 0 && (
    <CaseStudyCard
      title="Destaque de Sucesso"
      subtitle="Como ajudamos nossos parceiros a alcançarem a máxima eficiência operacional."
      cases={featuredCases}
      variant="featured"
      background="default"
    />
  )}

  {/* Seção de depoimento simplificada caso não queira usar o grid */}
  <CTA
    title="Sua empresa pode ser o próximo caso de sucesso"
    description="Agende uma conversa e veja como o Lumos se adapta ao seu contrato e às suas necessidades de campo."
    action={{ label: 'Solicitar Demonstração', href: '/contact' }}
    background="muted"
  />
</MarketingLayout>