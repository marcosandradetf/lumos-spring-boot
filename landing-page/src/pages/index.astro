<script>
  function initGallery() {
    const carousel = document.getElementById("carousel");
    const stripPrevButton = document.querySelector("[data-gallery-strip-prev]") as HTMLButtonElement | null;
    const stripNextButton = document.querySelector("[data-gallery-strip-next]") as HTMLButtonElement | null;
    const modal = document.getElementById("gallery-modal");
    const modalImage = document.getElementById("gallery-modal-image") as HTMLImageElement | null;
    const closeButton = document.querySelector("[data-gallery-close]");
    const prevButton = document.querySelector("[data-gallery-prev]");
    const nextButton = document.querySelector("[data-gallery-next]");

    if (!carousel || !modal || !modalImage || carousel.dataset.galleryReady === "true") return;
    carousel.dataset.galleryReady = "true";

    const items = Array.from(carousel.querySelectorAll("[data-gallery-item]")) as HTMLElement[];
    const imageSources = items
      .map((item) => item.getAttribute("data-src"))
      .filter((value): value is string => Boolean(value));

    if (!imageSources.length) return;

    let currentIndex = 0;

    function renderImage() {
      modalImage.src = imageSources[currentIndex];
    }

    function openModal(index: number) {
      currentIndex = index;
      renderImage();
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      modal.classList.add("hidden");
      document.body.style.overflow = "";
    }

    function goToNext() {
      currentIndex = (currentIndex + 1) % imageSources.length;
      renderImage();
    }

    function goToPrev() {
      currentIndex = (currentIndex - 1 + imageSources.length) % imageSources.length;
      renderImage();
    }

    function updateStripNavState() {
      if (!stripPrevButton || !stripNextButton) return;
      const maxScrollLeft = Math.max(carousel.scrollWidth - carousel.clientWidth, 0);
      stripPrevButton.disabled = carousel.scrollLeft <= 2;
      stripNextButton.disabled = carousel.scrollLeft >= maxScrollLeft - 2;
    }

    function scrollStrip(direction: 1 | -1) {
      const amount = Math.max(carousel.clientWidth * 0.78, 220);
      carousel.scrollBy({
        left: amount * direction,
        behavior: "smooth",
      });
    }

    items.forEach((item, i) => {
      item.addEventListener("click", () => openModal(i));
    });

    stripPrevButton?.addEventListener("click", () => scrollStrip(-1));
    stripNextButton?.addEventListener("click", () => scrollStrip(1));
    closeButton?.addEventListener("click", closeModal);
    prevButton?.addEventListener("click", goToPrev);
    nextButton?.addEventListener("click", goToNext);

    modal.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      if (target.closest("[data-gallery-backdrop]")) closeModal();
    });

    document.addEventListener("keydown", (event) => {
      if (modal.classList.contains("hidden")) return;
      if (event.key === "Escape") closeModal();
      if (event.key === "ArrowRight") goToNext();
      if (event.key === "ArrowLeft") goToPrev();
    });

    carousel.addEventListener("scroll", updateStripNavState);
    window.addEventListener("resize", updateStripNavState);
    updateStripNavState();
  }

  initGallery();
  document.addEventListener("astro:page-load", initGallery);
</script>

