---
// Props permanecem as mesmas
interface Props {
  action?: string;
  method?: 'POST' | 'GET';
  netlify?: boolean;
  formName?: string;
}

const { action = '', method = 'POST', netlify = false, formName = 'contact' } = Astro.props;
---

<form
  id="contact-form"
  action={action}
  method={method}
  class="space-y-6"
  data-netlify={netlify ? 'true' : undefined}
  name={netlify ? formName : undefined}
  novalidate
>
  <div class="hidden" aria-hidden="true">
    <label>Don't fill this: <input type="text" name="_gotcha" tabindex="-1" /></label>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="fullName" class="block text-sm font-medium text-text mb-2">
        Nome Completo <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="fullName"
        name="fullName"
        required
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text focus:ring-2 focus:ring-primary focus:outline-none"
        placeholder="Ex: José Romeu"
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="fullName"></p>
    </div>

    <div>
      <label for="subject" class="block text-sm font-medium text-text mb-2">
        Finalidade do Contato <span class="text-red-500">*</span>
      </label>
      <div class="relative">
        <select
          id="subject"
          name="subject"
          required
          class="w-full px-4 py-3 appearance-none rounded-md border border-border bg-background text-text focus:ring-2 focus:ring-primary focus:outline-none cursor-pointer"
        >
          <option value="">Selecione uma opção</option>
          <option value="sales">Quero contratar o Lumos (Vendas)</option>
          <option value="test">Quero uma Demonstração</option>
          <option value="support">Suporte Técnico / Abrir Ticket</option>
          <option value="partnership">Parcerias e Consultoria</option>
          <option value="other">Outros Assuntos</option>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
          <svg class="w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            d="M19 9l-7 7-7-7"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path></svg
          >
        </div>
      </div>
      <p class="mt-1 text-sm text-red-500 hidden" data-error="subject"></p>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

    <div>
      <label for="email" class="block text-sm font-medium text-text mb-2">
        E-mail Corporativo <span class="text-red-500">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text focus:ring-2 focus:ring-primary focus:outline-none"
        placeholder="jose@empresa.com.br"
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="email"></p>
    </div>

    <div>
      <label for="phone" class="block text-sm font-medium text-text mb-2">
        Melhor telefone <span class="text-red-500">*</span>
      </label>
      <input
        type="number"
        id="phone"
        name="phone"
        required
        class="w-full px-4 py-3 rounded-md border border-border bg-background text-text focus:ring-2 focus:ring-primary focus:outline-none"
        placeholder="Ex. 31990909090"
      />
      <p class="mt-1 text-sm text-red-500 hidden" data-error="phone"></p>
    </div>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-text mb-2">
      Mensagem ou Detalhes do Ticket <span class="text-red-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full px-4 py-3 rounded-md border border-border bg-background text-text focus:ring-2 focus:ring-primary focus:outline-none resize-none"
      placeholder="Descreva como podemos ajudar..."></textarea>
    <p class="mt-1 text-sm text-red-500 hidden" data-error="message"></p>
  </div>

  <div id="form-status" class="hidden">
    <div id="form-success" class="hidden p-4 rounded-md bg-green-50 border border-green-200">
      <p class="text-green-800 font-medium">Solicitação enviada!</p>
      <p class="text-green-700 text-sm mt-1">
        Seu protocolo foi gerado. Se for um ticket de suporte, verificaremos a prioridade do seu
        contrato.
      </p>
    </div>
    <div id="form-error" class="hidden p-4 rounded-md bg-red-50 border border-red-200">
      <p class="text-red-800 font-medium">Erro ao enviar</p>
      <p class="text-red-700 text-sm mt-1">
        Tente novamente ou envie diretamente para o e-mail de suporte.
      </p>
    </div>
  </div>

  <button
    type="submit"
    id="submit-button"
    class="w-full sm:w-auto px-8 py-4 rounded-md bg-primary text-white font-bold hover:bg-primary-dark transition-all disabled:opacity-50"
  >
    <span id="button-text">Enviar Solicitação</span>
    <span id="button-loading" class="hidden">Processando...</span>
  </button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('button-text');
  const buttonLoading = document.getElementById('button-loading');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // 1. Captura os dados do formulário
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // 2. JOGA NO CONSOLE (O que você pediu)
    console.log("🚀 Dados capturados para envio:", data);

    // 3. Exemplo de log específico por campo
    console.log("👤 Nome:", data.fullName);
    console.log("📧 E-mail:", data.email);
    console.log("📧 Phone:", data.phone);
    console.log("📂 Assunto:", data.subject);

    // --- Lógica de envio (Simulação) ---
    submitButton.disabled = true;
    buttonText?.classList.add('hidden');
    buttonLoading?.classList.remove('hidden');

    try {
      // Simulando o tempo de resposta do servidor
      await new Promise(resolve => setTimeout(resolve, 1000));

      console.log("✅ Simulação de envio concluída com sucesso!");

      // Mostrar mensagem de sucesso na tela
      document.getElementById('form-status')?.classList.remove('hidden');
      document.getElementById('form-success')?.classList.remove('hidden');
      form.reset();
    } catch (error) {
      console.error("❌ Erro na simulação:", error);
    } finally {
      submitButton.disabled = false;
      buttonText?.classList.remove('hidden');
      buttonLoading?.classList.add('hidden');
    }
  });
</script>
