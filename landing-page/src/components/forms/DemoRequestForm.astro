---
import { Icon } from 'astro-icon/components';

/**
 * DemoRequestForm - Demo request form with validation
 *
 * @description
 * A form for requesting product demos with company info, team size,
 * and optional message. Supports Netlify Forms, Formspree, and custom endpoints.
 * Runs in demo mode (simulates success) when no action URL is provided.
 *
 * @example Demo mode (no backend)
 * ```astro
 * <DemoRequestForm />
 * ```
 *
 * @example Netlify Forms
 * ```astro
 * <DemoRequestForm netlify formName="demo-request" />
 * ```
 *
 * @example Custom endpoint
 * ```astro
 * <DemoRequestForm action="https://api.example.com/demo" method="POST" />
 * ```
 */

interface Props {
  /** Form action URL - leave empty for client-side only demo */
  action?: string;
  /** HTTP method for form submission */
  method?: 'POST' | 'GET';
  /** Form behavior and copy */
  variant?: 'demo' | 'free-test';
  /** Enable Netlify Forms integration */
  netlify?: boolean;
  /** Form name for Netlify Forms */
  formName?: string;
  /** Plan sent to the free-test controller */
  planName?: string;
  /** Redirect target after a successful submission */
  redirectUrl?: string;
  /** Submit button label */
  submitLabel?: string;
}

const {
  action = '',
  method = 'POST',
  variant = 'demo',
  netlify = false,
  formName = 'demo-request',
  planName = 'Profissional',
  redirectUrl = '',
  submitLabel = variant === 'free-test' ? 'Criar meu teste grĂˇtis' : 'Enviar FormulĂˇrio',
} = Astro.props;

const isFreeTest = variant === 'free-test';
---

<form
  id="demo-request-form"
  action={action}
  method={method}
  class="space-y-5"
  data-netlify={netlify ? 'true' : undefined}
  data-variant={variant}
  data-redirect={redirectUrl}
  name={netlify ? formName : undefined}
  novalidate
>
  <!-- Honeypot field for spam protection -->
  <div class="hidden" aria-hidden="true">
    <label>
      Don't fill this out if you're human:
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <!-- Netlify hidden field -->
  {netlify && <input type="hidden" name="form-name" value={formName} />}
  {isFreeTest && <input type="hidden" name="planName" value={planName} />}
  {isFreeTest && <input type="hidden" name="useTrial" value="true" />}

  {
    isFreeTest ? (
      <div class="space-y-6">
        <div class="rounded-xl border border-border bg-background/70 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-bold text-text">
                Conte com o suporte do nosso time para comeĂ§ar
              </p>
              <p class="mt-1 text-xs text-text-muted">
                Respondemos rĂˇpido para ajudar vocĂŞ a tirar valor do teste.
              </p>
            </div>
            <span
              id="wizard-progress-number"
              class="shrink-0 text-xs font-bold uppercase tracking-widest text-primary"
            >
              1/5
            </span>
          </div>
          <div class="mt-4 h-2 overflow-hidden rounded-full bg-border">
            <div
              id="wizard-progress-bar"
              class="h-full w-1/5 rounded-full bg-primary transition-all duration-300"
            />
          </div>
        </div>

        <div class="wizard-step space-y-6" data-wizard-step>
          <div class="space-y-4 pt-1">
            <p class="text-2xl font-light leading-snug text-text">
              <strong class="font-bold">
                Assuma o controle total da sua operaĂ§ĂŁo de IluminaĂ§ĂŁo PĂşblica.
              </strong>
            </p>
            <p class="text-base leading-relaxed text-text-muted">
              Conecte suas equipes de campo ao faturamento em tempo real. O Lumos elimina o gap
              entre o serviĂ§o executado e a mediĂ§ĂŁo aprovada, substituindo planilhas frĂˇgeis por
              gestĂŁo de dados auditĂˇveis.
            </p>
            <p class="text-sm font-semibold italic text-text">
              14 dias grĂˇtis. NĂŁo precisa de cartĂŁo de crĂ©dito.
            </p>
          </div>

          <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="rounded-lg border border-border bg-background px-3 py-4">
