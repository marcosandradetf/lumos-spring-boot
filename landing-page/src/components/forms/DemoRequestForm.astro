          />
          <p class="mt-1 text-sm text-red-500 hidden" data-error="demo-email" />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-text mb-2">
            Melhor telefone <span class="text-red-500">*</span>
          </label>
          <input
            maxlength="11"
            type="number"
            id="phone"
            name="phone"
            required
            class="w-full px-4 py-3 rounded-lg border border-border bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
            placeholder="Ex. 31990909090"
          />
          <p class="mt-1 text-sm text-red-500 hidden" data-error="phone" />
        </div>

        <div>
          <label for="demo-company" class="block text-sm font-medium text-text mb-2">
            Empresa <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="demo-company"
            name="company"
            required
            class="w-full px-4 py-3 rounded-lg border border-border bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
            placeholder="Empresa Ltda"
          />
          <p class="mt-1 text-sm text-red-500 hidden" data-error="demo-company" />
        </div>

        <div>
          <label for="demo-teamSize" class="block text-sm font-medium text-text mb-2">
            Tamanho da Equipe <span class="text-red-500">*</span>
          </label>
          <div class="relative">
            <select
              id="demo-teamSize"
              name="teamSize"
              required
              class="w-full px-4 py-3 pr-10 rounded-lg border border-border bg-background text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors appearance-none cursor-pointer"
            >
              <option value="">Selecione o tamanho da sua equipe</option>
              <option value="1-10">1-10 colaboradores</option>
              <option value="11-50">11-50 colaboradores</option>
              <option value="51-200">51-200 colaboradores</option>
              <option value="200+">200+ colaboradores</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-text-muted">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"
                />
              </svg>
            </div>
          </div>
          <p class="mt-1 text-sm text-red-500 hidden" data-error="demo-teamSize" />
        </div>

        <div>
          <label for="demo-message" class="block text-sm font-medium text-text mb-2">
            Qual rotina vocĂŞ quer melhorar primeiro? <span class="text-text-muted">(Opcional)</span>
          </label>
          <textarea
            id="demo-message"
            name="message"
            rows="3"
            class="w-full px-4 py-3 rounded-lg border border-border bg-background text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary resize-none transition-colors"
            placeholder="Ex. acompanhar equipes em campo, controlar contratos ou organizar chamados..."
          />
        </div>
      </>
    )
  }

  <!-- Form status messages -->
  <div id="demo-form-status" class="hidden">
    <div
      id="demo-form-success"
      class="hidden p-6 rounded-2xl border border-emerald-500/30 bg-emerald-500/5 backdrop-blur-sm transition-all animate-in fade-in zoom-in duration-300"
    >
      <div class="flex items-start gap-4">
        <div
          class="shrink-0 w-10 h-10 rounded-full bg-emerald-500/20 flex items-center justify-center"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 text-emerald-500"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline
              points="22 4 12 14.01 9 11.01"></polyline></svg
          >
        </div>
        <div>
          <p class="text-[var(--color-text)] font-bold text-lg">SolicitaĂ§ĂŁo confirmada!</p>
          <p class="text-[var(--color-text-muted)] text-sm mt-1 leading-relaxed">
            {
              isFreeTest
                ? 'Sua conta foi criada. VocĂŞ jĂˇ pode acessar o Lumos com o e-mail e a senha cadastrados.'
                : 'Seu ambiente estĂˇ sendo preparado. Retornaremos em instantes com as instruĂ§Ăµes de acesso ao sistema.'
            }
          </p>
          <div class="mt-4 flex gap-3">
            <a
              href={isFreeTest ? 'https://lumos.thryon.com.br/auth/login' : '/como-usar'}
              class="text-xs font-bold uppercase tracking-wider text-[var(--color-primary)] hover:underline"
            >
              {isFreeTest ? 'Acessar o Lumos' : 'Ver Guia RĂˇpido de como usar â†’'}
            </a>
          </div>
        </div>
      </div>
    </div>
    <div
      id="demo-form-error"
      class="hidden p-4 rounded-lg bg-red-100 dark:bg-red-950 border border-red-300 dark:border-red-800"
    >
      <p class="text-red-900 dark:text-red-100 font-medium">Algo deu errado</p>
      <p id="demo-form-error-message" class="text-red-800 dark:text-red-300 text-sm mt-1">
        Por favor, tente novamente ou entre em contato conosco diretamente por e-mail.
      </p>
    </div>
  </div>

  <button
    type="submit"
    id="demo-submit-button"
    class={`w-full cursor-pointer px-6 py-4 rounded-lg bg-primary text-white font-semibold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed items-center justify-center gap-2 ${isFreeTest ? 'hidden' : 'flex'}`}
  >
    <span id="demo-button-text">{submitLabel}</span>
    <span id="demo-button-loading" class="hidden">
      <svg
        class="animate-spin inline-block w-5 h-5 mr-2"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"
        ></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
      Enviando...
    </span>
    <svg
      id="demo-button-arrow"
      class="w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
    </svg>
  </button>

  <p class="text-xs text-text-muted text-center">
    Ao enviar, vocĂŞ concorda com nossos termos. <a
      href="/privacidade"
      class="underline hover:text-primary">PolĂ­tica de Privacidade</a
    >.
  </p>
</form>

<script>
  const form = document.getElementById('demo-request-form') as HTMLFormElement;
  const submitButton = document.getElementById('demo-submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('demo-button-text');
  const buttonLoading = document.getElementById('demo-button-loading');
  const buttonArrow = document.getElementById('demo-button-arrow');
  const formStatus = document.getElementById('demo-form-status');
  const formSuccess = document.getElementById('demo-form-success');
  const formError = document.getElementById('demo-form-error');
  const formErrorMessage = document.getElementById('demo-form-error-message');
  const variant = form.dataset.variant;
  const wizardSteps = Array.from(form.querySelectorAll<HTMLElement>('[data-wizard-step]'));
  const progressNumber = document.getElementById('wizard-progress-number');
  const progressBar = document.getElementById('wizard-progress-bar');
  let currentWizardStep = 0;

  const demoCompany = document.getElementById('demo-company') as HTMLInputElement;
  // Supondo que vocĂŞ queira exibir isso em algum lugar ou preencher um campo oculto
  const demoUserDisplay = document.getElementById('demo-user-display');

  // Troque 'blur' por 'input' para ser em tempo real
  demoCompany?.addEventListener('input', () => {
    const companyName = demoCompany.value.trim();
    if (companyName.length > 0) {
      const adminSlug = companyName
        .split(' ')[0]
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]/g, ''); // Garante que nĂŁo tenha sĂ­mbolos especiais

      if (demoUserDisplay) {
        demoUserDisplay.textContent = `admin-${adminSlug}`;
      }
    }
  });

  const cnpjInput = document.getElementById('demo-cnpj') as HTMLInputElement;
  cnpjInput?.addEventListener('input', (e) => {
    let value = cnpjInput.value.replace(/\D/g, '');
    if (value.length > 14) value = value.slice(0, 14);

    // Aplica a mĂˇscara dinamicamente
    value = value.replace(/^(\d{2})(\d)/, '$1.$2');
    value = value.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
    value = value.replace(/\.(\d{3})(\d)/, '.$1/$2');
    value = value.replace(/(\d{4})(\d)/, '$1-$2');

    cnpjInput.value = value;
  });

  const telInput = document.getElementById('phone') as HTMLInputElement;

  telInput?.addEventListener('input', () => {
    let value = telInput.value.replace(/\D/g, '');

    // Limita a 11 dĂ­gitos (DDD + nĂşmero com 9 dĂ­gitos)
    if (value.length > 11) value = value.slice(0, 11);

    // Aplica mĂˇscara dinĂ˘mica
    if (value.length <= 10) {
      // Telefone fixo: (31) 3190-9090
      value = value.replace(/^(\d{2})(\d)/, '($1) $2');
      value = value.replace(/(\d{4})(\d)/, '$1-$2');
    } else {
      // Celular: (31) 9 3190-9090
      value = value.replace(/^(\d{2})(\d)/, '($1) $2 ');
      value = value.replace(/(\d{1}) (\d{4})(\d)/, '$1 $2-$3');
    }

    telInput.value = value;
  });

  // Validation rules
  const validationRules: Record<string, (value: string) => string | null> = {
    'demo-firstName': (value) => {
      if (!value.trim()) return 'O primeiro nome Ă© obrigatĂłrio';
      if (value.trim().length < 2) return 'O primeiro nome deve ter pelo menos 2 caracteres';
      return null;
    },
    'demo-lastName': (value) => {
      if (!value.trim()) return 'Sobrenome Ă© obrigatĂłrio';
      if (value.trim().length < 2) return 'O sobrenome deve ter pelo menos 2 caracteres';
      return null;
    },
    'demo-email': (value) => {
      if (!value.trim()) return 'Email Ă© obrigatĂłrio';
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(value)) return 'Por favor, insira um endereĂ§o de e-mail vĂˇlido';
      return null;
    },
    phone: (value) => {
      if (!value.trim()) return 'Telefone Ă© obrigatĂłrio';
      const phoneRegex = /^\(\d{2}\)\s\d\s\d{4}-\d{4}$|^\(\d{2}\)\s\d{4}-\d{4}$/;
      if (!phoneRegex.test(value)) return 'Por favor, insira um telefone vĂˇlido';
      return null;
    },
    'demo-company': (value) => {
      if (!value.trim()) return 'Nome da empresa Ă© obrigatĂłrio';
      return null;
    },
    'demo-teamSize': (value) => {
      if (!value) return 'Por favor, selecione o tamanho da equipe';
      return null;
    },
    // No seu objeto validationRules, substitua a regra do CPF por esta:
    'demo-cnpj': (value) => {
      if (!value.trim()) return 'CNPJ Ă© obrigatĂłrio para o teste corporativo';

      // Regex que aceita apenas os 14 nĂşmeros ou o formato com pontos/barras
      const cnpjRegex = /^\d{2}\.?\d{3}\.?\d{3}\/?\d{4}-?\d{2}$/;
      if (!cnpjRegex.test(value)) return 'Insira um CNPJ vĂˇlido (00.000.000/0000-00)';

      return null;
    },
  };

  if (variant === 'free-test') {
    validationRules['demo-operationFocus'] = (value) => {
      if (!value.trim()) return 'Escolha a principal rotina da empresa';
      return null;
    };
    validationRules['demo-currentMoment'] = (value) => {
      if (!value.trim()) return 'Escolha o momento da sua empresa';
      return null;
    };
    validationRules['demo-password'] = (value) => {
      if (!value.trim()) return 'Senha Ă© obrigatĂłria';
      if (value.length < 8) return 'A senha deve ter pelo menos 8 caracteres';
      return null;
    };
  }

  // Show/hide error message
  function showError(fieldId: string, message: string | null) {
    const errorEl = document.querySelector(`[data-error="${fieldId}"]`);
    const inputEl = document.getElementById(fieldId);

    if (errorEl && inputEl) {
      if (message) {
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
        inputEl.classList.add('border-red-500');
        inputEl.classList.remove('border-border');
      } else {
        errorEl.classList.add('hidden');
        inputEl.classList.remove('border-red-500');
        inputEl.classList.add('border-border');
      }
    }
  }

  // Validate single field
  function validateField(fieldId: string): boolean {
    const input = document.getElementById(fieldId) as HTMLInputElement | HTMLSelectElement | null;
    if (!input || !validationRules[fieldId]) return true;

    const error = validationRules[fieldId](input.value);
    showError(fieldId, error);
    return !error;
  }

  // Validate all fields
  function validateForm(): boolean {
    let isValid = true;
    for (const fieldId of Object.keys(validationRules)) {
      if (!validateField(fieldId)) {
        isValid = false;
      }
    }
    return isValid;
  }

  function validateCurrentStep(): boolean {
    const step = wizardSteps[currentWizardStep];
    if (!step) return true;

    const fields = Array.from(
      step.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[id]')
    ).filter((field) => validationRules[field.id]);

    let isValid = true;
    for (const field of fields) {
      if (!validateField(field.id)) {
        isValid = false;
      }
    }

    if (!isValid) {
      const firstError = step.querySelector('.border-red-500') as HTMLElement;
      firstError?.focus();
    }

    return isValid;
  }

  function updateWizard() {
    if (!wizardSteps.length) return;

    wizardSteps.forEach((step, index) => {
      step.classList.toggle('hidden', index !== currentWizardStep);
    });

    const total = wizardSteps.length;
    if (progressNumber) progressNumber.textContent = `${currentWizardStep + 1}/${total}`;
    if (progressBar) progressBar.style.width = `${((currentWizardStep + 1) / total) * 100}%`;

    if (currentWizardStep === total - 1) {
      submitButton.classList.remove('hidden');
      submitButton.classList.add('flex');
    } else if (variant === 'free-test') {
      submitButton.classList.add('hidden');
      submitButton.classList.remove('flex');
    }
  }

  function setChoice(button: HTMLButtonElement) {
    const targetId = button.dataset.choiceTarget;
    const value = button.dataset.choiceValue || '';
    if (!targetId) return;

    const target = document.getElementById(targetId) as HTMLInputElement | null;
    if (!target) return;

    target.value = value;
    validateField(targetId);

    const group = form.querySelectorAll<HTMLButtonElement>(`[data-choice-target="${targetId}"]`);
    group.forEach((choice) => {
      const isSelected = choice === button;
      choice.classList.toggle('border-primary', isSelected);
      choice.classList.toggle('bg-primary/10', isSelected);
      choice.classList.toggle('border-border', !isSelected);
    });
  }

  // Real-time validation on blur
  for (const fieldId of Object.keys(validationRules)) {
    const input = document.getElementById(fieldId) as HTMLInputElement | HTMLSelectElement | null;
    if (input) {
      // input.addEventListener('blur', () => validateField(fieldId));
      input.addEventListener('input', () => {
        const errorEl = document.querySelector(`[data-error="${fieldId}"]`);
        if (errorEl && !errorEl.classList.contains('hidden')) {
          validateField(fieldId);
        }
      });
    }
  }

  form.querySelectorAll<HTMLButtonElement>('[data-wizard-next]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!validateCurrentStep()) return;
      currentWizardStep = Math.min(currentWizardStep + 1, wizardSteps.length - 1);
      updateWizard();
    });
  });

  form.querySelectorAll<HTMLButtonElement>('[data-wizard-back]').forEach((button) => {
    button.addEventListener('click', () => {
      currentWizardStep = Math.max(currentWizardStep - 1, 0);
      updateWizard();
    });
  });

  form.querySelectorAll<HTMLButtonElement>('[data-choice-target]').forEach((button) => {
    button.addEventListener('click', () => setChoice(button));
  });

  // Form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Hide previous status messages
    formStatus?.classList.add('hidden');
    formSuccess?.classList.add('hidden');
    formError?.classList.add('hidden');

    if (variant === 'free-test' && currentWizardStep < wizardSteps.length - 1) {
      if (validateCurrentStep()) {
        currentWizardStep += 1;
        updateWizard();
      }
      return;
    }

    // Validate form
    if (!validateForm()) {
      const firstError = form.querySelector('.border-red-500') as HTMLElement;
      firstError?.focus();
      return;
    }

    // Show loading state
    submitButton.disabled = true;
    buttonText?.classList.add('hidden');
    buttonArrow?.classList.add('hidden');
    buttonLoading?.classList.remove('hidden');

    const formData = new FormData(form);
    const action = form.action;

    try {
      // If no action URL, simulate success (demo mode)
      if (!action) {
        await new Promise((resolve) => setTimeout(resolve, 1500));
        showSuccess();
        return;
      }

      // Submit to actual endpoint
      const response = await fetch(action, {
        method: form.method || 'POST',
        body: formData,
        credentials: 'include',
        headers: {
          Accept: 'application/json',
        },
      });

      if (response.ok) {
        const data = await response.json();
        showSuccess();
        localStorage.setItem('accessToken', data.accessToken);
        const redirectUrl = `https://app.lumosip.com.br/auth/auto-login`;

        setTimeout(() => {
          window.location.href = redirectUrl;
        }, 2000);
      } else {
        showErrorState(await getErrorMessage(response));
      }
    } catch {
      showErrorState();
    }
  });

  async function getErrorMessage(response: Response): Promise<string | undefined> {
    try {
      const body = await response.json();
      if (typeof body?.message === 'string') return body.message;
      if (typeof body?.error === 'string') return body.error;
    } catch {
      return undefined;
    }

    return undefined;
  }

  function showSuccess() {
    formStatus?.classList.remove('hidden');
    formSuccess?.classList.remove('hidden');
    form.reset();
    currentWizardStep = 0;
    updateWizard();
    resetChoiceButtons();
    resetButtonState();
  }

  function showErrorState(message?: string) {
    formStatus?.classList.remove('hidden');
    formError?.classList.remove('hidden');
    if (formErrorMessage) {
      formErrorMessage.textContent =
        message || 'Por favor, tente novamente ou entre em contato conosco diretamente por e-mail.';
    }
    resetButtonState();
  }

  function resetButtonState() {
    submitButton.disabled = false;
    buttonText?.classList.remove('hidden');
    buttonArrow?.classList.remove('hidden');
    buttonLoading?.classList.add('hidden');
  }

  function resetChoiceButtons() {
    form.querySelectorAll<HTMLButtonElement>('[data-choice-target]').forEach((choice) => {
      choice.classList.remove('border-primary', 'bg-primary/10');
      choice.classList.add('border-border');
    });
  }

  updateWizard();
</script>
